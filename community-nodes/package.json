{
  "name": "community-nodes",
  "version": "0.0.0",
  "description": "",
  "license": "Apache-2.0",
  "homepage": "",
  "keywords": [
    "bcgov-community-nodes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bcgov/common-hosted-workflow.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/ChefsApi.credentials.js",
      "dist/credentials/ChefsFormAuth.credentials.js",
      "dist/credentials/DevXConnector.credentials.js",
      "dist/credentials/OidcToken.credentials.js",
      "dist/credentials/WorkflowInteractionLayerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CHEFS/CHEFS.node.js",
      "dist/nodes/CHEFSResubmitWait/CHEFSResubmitWait.node.js",
      "dist/nodes/CHEFSSubmissionExtractor/CHEFSSubmissionExtractor.node.js",
      "dist/nodes/DevXMessageConnector/DevXMessageConnector.node.js",
      "dist/nodes/OidcToken/OidcToken.node.js",
      "dist/nodes/MultiWebhookWait/MultiWebhookWait.node.js",
      "dist/nodes/WorkflowInteractionLayer/WorkflowInteractionLayer.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@n8n/eslint-plugin-community-nodes": "^0.25.0",
    "@n8n/node-cli": "^0.30.1",
    "@types/node": "^25.9.5",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-n8n-nodes-base": "1.16.7",
    "n8n-core": "^2.16.1",
    "n8n-nodes-base": "^2.15.1",
    "n8n-workflow": "^2.16.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "n8n-workflow": "^2.16.0"
  },
  "dependencies": {
    "sanitize-html": "^2.17.6",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "eslint-plugin-n8n-nodes-base": "1.16.7"
    }
  }
