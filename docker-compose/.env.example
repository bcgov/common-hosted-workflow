## Copy this file to .env before running docker compose.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

OLLAMA_HOST=ollama:11434

# For Mac users running OLLAMA locally instead of in Docker, override with:
# OLLAMA_HOST=host.docker.internal:11434

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password
OIDC_CLIENT_ID=app
OIDC_CLIENT_SECRET=testsecret
OIDC_AUTHORIZATION_ENDPOINT=http://localhost:8080/realms/starter/protocol/openid-connect/auth
OIDC_TOKEN_ENDPOINT=http://keycloak:8080/realms/starter/protocol/openid-connect/token
OIDC_USERINFO_ENDPOINT=http://keycloak:8080/realms/starter/protocol/openid-connect/userinfo
OIDC_JWKS_URI=http://keycloak:8080/realms/starter/protocol/openid-connect/certs
OIDC_END_SESSION_ENDPOINT=http://localhost:8080/realms/starter/protocol/openid-connect/logout
UI_AUTH_JWT_SECRET=testsecret
UI_OIDC_REDIS_PREFIX=chwf:ui-oidc:
UI_OIDC_REDIS_URL=redis://redis:6379
UI_OIDC_REDIS_PASSWORD=
UI_AUTH_USE_SEPARATE_TOKEN=false
UI_APP_BASE_URL=http://localhost:5173/ui
N8N_BASE_URL=http://localhost:5678
DEVX_CONNECTOR_API_URL=
DEVX_CONNECTOR_API_KEY=

# Internal API credentials for secure communication between n8n and external hooks
INTERNAL_AUTH_TOKEN=super-internal-auth-token

# CSS SSO API credentials for role assignment on access request approval
AUTHZ_SERVICE_URL=https://api.loginproxy.gov.bc.ca/api/v1
AUTHZ_INTEGRATION_ID=
AUTHZ_ENVIRONMENT=
AUTHZ_TOKEN_ENDPOINT=
AUTHZ_CLIENT_ID=
AUTHZ_CLIENT_SECRET=

# CHEFS – Common Hosted Form Service (base URL; gateway path is appended automatically)
CHEFS_BASE_URL=https://chefs-dev.apps.silver.devops.gov.bc.ca

# CSTAR – Tenant & user management (base URL; /api/v1 is appended automatically)
CSTAR_BASE_URL=http://host.docker.internal:8081

# Feature flags — JSON string mapping flag names to booleans.
# See feature-flags.config.json.example for the expected shape.
FEATURE_FLAG_CONFIG={"CSTAR_FEATURE":false,"PROJECT_FEATURE":false,"TENANT_PROJECT_SYNC":true}
