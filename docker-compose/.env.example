POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# For Mac users running OLLAMA locally
# See https://github.com/n8n-io/self-hosted-ai-starter-kit?tab=readme-ov-file#for-mac--apple-silicon-users
# OLLAMA_HOST=host.docker.internal:11434

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password
OIDC_CLIENT_ID=app
OIDC_CLIENT_SECRET=testsecret
AUTH_REDIRECT_URIS=http://localhost:5678/rest/auth/oidc/callback,http://localhost:5173/ui-api/auth/callback,http://localhost:5678/ui-api/auth/callback,http://127.0.0.1:5678/ui-api/auth/callback,http://keycloak:5678/ui-api/auth/callback
UI_AUTH_JWT_SECRET=testsecret
UI_OIDC_REDIS_PREFIX=chwf:ui-oidc:
UI_OIDC_REDIS_URL=redis://localhost:6379
UI_OIDC_ISSUER=http://localhost:8080/realms/starter
UI_OIDC_CLIENT_ID=app
UI_OIDC_CLIENT_SECRET=testsecret
UI_OIDC_REDIRECT_URI=http://localhost:5173/ui-api/auth/callback
UI_OIDC_SCOPES=openid email profile

# Internal API credentials for secure communication between n8n and external hooks
INTERNAL_AUTH_TOKEN=super-internal-auth-token
