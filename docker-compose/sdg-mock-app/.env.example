# Base URL of the n8n instance for the Next.js rewrite proxy
N8N_TARGET=http://localhost:5678

# CHEF Base URL (used by API routes and the form viewer web component)
CHEFS_BASE_URL=https://submit.digital.gov.bc.ca/app

# Workflow Interaction Layer credentials (server-side only)
X_N8N_API_KEY=your-api-key-here
X_TENANT_ID=your-tenant-id-here
