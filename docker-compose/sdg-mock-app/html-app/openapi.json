{
  "openapi": "3.1.0",
  "info": {
    "title": "CHWF Workflow Interaction Layer APIs — Messages, Action Requests, Tenant Project Admin",
    "version": "0.4.0",
    "description": "Workflow interaction layer: message and action_request endpoints scoped by tenant and the caller's n8n project access. POST create for messages and actions requires INTERNAL_AUTH_TOKEN bearer plus X-N8N-API-KEY. Admin endpoint inserts/validates tenant_project_relation mappings used by tenant scoping."
  },
  "servers": [
    {
      "url": "https://{{host}}"
    }
  ],
  "tags": [{ "name": "Messages" }, { "name": "ActionRequests" }, { "name": "Admin" }],
  "components": {
    "securitySchemes": {
      "n8nApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-N8N-API-KEY",
        "description": "n8n API key (required for message and action endpoints + admin endpoints)."
      },
      "internalBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "INTERNAL-only bearer token. Must match env var INTERNAL_AUTH_TOKEN. Required for POST /rest/custom/v1/messages/ and POST /rest/custom/v1/actions (in addition to X-N8N-API-KEY and X-TENANT-ID)."
      }
    },
    "parameters": {
      "XTenantId": {
        "in": "header",
        "name": "X-TENANT-ID",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid",
          "description": "Tenant UUID used to load allowed projects from tenant_project_relation."
        }
      },
      "Since": {
        "name": "since",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date-time"
        },
        "description": "ISO-8601 datetime. Filters rows with createdAt >= since."
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 50
        }
      },
      "ActorIdQuery": {
        "name": "actorId",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "ActorIdPath": {
        "name": "actorId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "WorkflowInstanceIdQuery": {
        "name": "workflowInstanceId",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Optional. When set, the n8n execution id must exist and belong to a workflow/project in the caller's tenant scope (intersected with accessible projects)."
      },
      "ActionIdPath": {
        "name": "actionId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "schemas": {
      "Message": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "actorId": { "type": "string" },
          "actorType": {
            "type": "string",
            "enum": ["user", "role", "group", "system", "other"]
          },
          "workflowInstanceId": { "type": "string" },
          "workflowId": { "type": "string" },
          "projectId": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "read"] },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "MessageListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Message" }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true,
            "description": "ISO datetime cursor for pagination, or null when no next page."
          }
        }
      },
      "PostMessageRequest": {
        "type": "object",
        "required": ["title", "body", "actorId", "actorType", "workflowInstanceId", "workflowId"],
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "actorId": { "type": "string" },
          "actorType": {
            "type": "string",
            "enum": ["user", "role", "group", "system", "other"]
          },
          "workflowInstanceId": { "type": "string" },
          "workflowId": { "type": "string" },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": ["active", "read"],
            "nullable": true,
            "description": "Defaults to active if omitted."
          }
        }
      },
      "ActionRequest": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "actionType": { "type": "string" },
          "payload": { "type": "object", "additionalProperties": true },
          "callbackUrl": { "type": "string" },
          "callbackMethod": { "type": "string", "description": "HTTP verb for callbacks (e.g. POST)." },
          "callbackPayloadSpec": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          },
          "actorId": { "type": "string" },
          "actorType": {
            "type": "string",
            "enum": ["user", "role", "group", "system", "other"]
          },
          "workflowInstanceId": { "type": "string" },
          "workflowId": { "type": "string" },
          "projectId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled", "expired", "deleted"]
          },
          "priority": { "type": "string", "enum": ["critical", "normal"] },
          "dueDate": { "type": "string", "format": "date-time", "nullable": true },
          "checkIn": { "type": "string", "format": "date-time", "nullable": true },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ActionListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ActionRequest" }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true,
            "description": "ISO datetime cursor for pagination, or null when no next page."
          }
        }
      },
      "PostActionRequest": {
        "type": "object",
        "required": [
          "actionType",
          "payload",
          "callbackUrl",
          "actorId",
          "actorType",
          "workflowInstanceId",
          "workflowId"
        ],
        "properties": {
          "actionType": { "type": "string" },
          "payload": { "type": "object", "additionalProperties": true },
          "callbackUrl": { "type": "string" },
          "callbackMethod": {
            "type": "string",
            "description": "Defaults to POST when omitted; normalized to uppercase."
          },
          "callbackPayloadSpec": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          },
          "actorId": { "type": "string" },
          "actorType": {
            "type": "string",
            "enum": ["user", "role", "group", "system", "other"]
          },
          "workflowInstanceId": { "type": "string" },
          "workflowId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled", "expired", "deleted"],
            "description": "Defaults to pending when omitted."
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "normal"],
            "description": "Defaults to normal when omitted."
          },
          "dueDate": { "type": "string", "format": "date-time", "nullable": true },
          "checkIn": { "type": "string", "format": "date-time", "nullable": true },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          }
        }
      },
      "PatchActionStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled", "expired", "deleted"]
          }
        }
      },
      "PatchActionStatusResponse": {
        "type": "object",
        "required": ["status", "message"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled", "expired", "deleted"]
          },
          "message": {
            "type": "string",
            "description": "Human-readable confirmation. When status is deleted, indicates the action has been deleted."
          }
        }
      },
      "TenantProjectRelationRequest": {
        "type": "object",
        "required": ["tenantId", "projectId"],
        "description": "At most one project per tenant: if the tenant already has a mapping, POST returns 409 with conflictProjectId unless the same (tenantId, projectId) pair is sent (idempotent 200).",
        "properties": {
          "tenantId": { "type": "string", "format": "uuid" },
          "projectId": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "conflictTenantId": { "type": "string", "nullable": true },
          "conflictProjectId": { "type": "string", "nullable": true }
        }
      }
    }
  },
  "paths": {
    "/rest/custom/v1/actors/{actorId}/messages": {
      "get": {
        "tags": ["Messages"],
        "summary": "List messages for a specific actor (tenant-scoped)",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActorIdPath" },
          { "$ref": "#/components/parameters/Since" },
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/WorkflowInstanceIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "OK — array of messages (no wrapper object).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Message" }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query/path params (e.g. invalid since, limit, workflowInstanceId, or tenant header).",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid X-N8N-API-KEY",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant/user scope intersection missing, or workflowInstanceId not in scope",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/rest/custom/v1/messages/": {
      "get": {
        "tags": ["Messages"],
        "summary": "List messages (tenant-scoped)",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActorIdQuery" },
          { "$ref": "#/components/parameters/Since" },
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/WorkflowInstanceIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageListResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid query params",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid X-N8N-API-KEY",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant/user scope intersection missing, or workflowInstanceId not in scope",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      },
      "post": {
        "tags": ["Messages"],
        "summary": "Create message (internal-only, tenant-scoped)",
        "description": "Requires X-N8N-API-KEY, X-TENANT-ID, and Authorization: Bearer matching INTERNAL_AUTH_TOKEN. workflowInstanceId is validated against n8n execution data and must match workflowId; project is resolved from workflow within tenant scope.",
        "security": [{ "n8nApiKey": [] }, { "internalBearer": [] }],
        "parameters": [{ "$ref": "#/components/parameters/XTenantId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PostMessageRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": {
            "description": "Invalid payload (e.g., actorType/status invalid) or invalid workflowInstanceId",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid internal bearer token or missing caller",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant scope or workflow/project scope mismatch",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/rest/custom/v1/actions": {
      "get": {
        "tags": ["ActionRequests"],
        "summary": "List action requests (tenant-scoped)",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActorIdQuery" },
          { "$ref": "#/components/parameters/Since" },
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/WorkflowInstanceIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActionListResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid query params",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid X-N8N-API-KEY",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant/user scope or workflowInstanceId not in scope",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      },
      "post": {
        "tags": ["ActionRequests"],
        "summary": "Create action request (internal-only, tenant-scoped)",
        "description": "Requires X-N8N-API-KEY, X-TENANT-ID, and Authorization: Bearer matching INTERNAL_AUTH_TOKEN. workflowInstanceId is validated against n8n execution data and must match workflowId; project is resolved from workflow within tenant scope.",
        "security": [{ "n8nApiKey": [] }, { "internalBearer": [] }],
        "parameters": [{ "$ref": "#/components/parameters/XTenantId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PostActionRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActionRequest" }
              }
            }
          },
          "400": {
            "description": "Invalid payload or invalid workflowInstanceId",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid internal bearer or API key",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant scope or workflow not accessible",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error (e.g. INTERNAL_AUTH_TOKEN not configured)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/rest/custom/v1/actors/{actorId}/actions": {
      "get": {
        "tags": ["ActionRequests"],
        "summary": "List action requests for a specific actor (tenant-scoped)",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActorIdPath" },
          { "$ref": "#/components/parameters/Since" },
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/WorkflowInstanceIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActionListResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid query/path params",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid X-N8N-API-KEY",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant/user scope or workflowInstanceId not in scope",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/rest/custom/v1/actions/{actionId}": {
      "get": {
        "tags": ["ActionRequests"],
        "summary": "Get action request by id (tenant-scoped)",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActionIdPath" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActionRequest" }
              }
            }
          },
          "400": {
            "description": "Invalid actionId",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid X-N8N-API-KEY",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant/user scope missing",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "404": {
            "description": "Action not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      },
      "patch": {
        "tags": ["ActionRequests"],
        "summary": "Update action request status (tenant-scoped)",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActionIdPath" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PatchActionStatusRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PatchActionStatusResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid status or actionId",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid X-N8N-API-KEY",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant/user scope missing",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "404": {
            "description": "Action not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/rest/custom/v1/actors/{actorId}/actions/{actionId}": {
      "get": {
        "tags": ["ActionRequests"],
        "summary": "Get action request by id and actor (tenant-scoped)",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActorIdPath" },
          { "$ref": "#/components/parameters/ActionIdPath" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActionRequest" }
              }
            }
          },
          "400": {
            "description": "Invalid path params",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing/invalid X-N8N-API-KEY",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "403": {
            "description": "Tenant/user scope missing",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "404": {
            "description": "Action not found (including actor mismatch)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal Server Error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      },
      "patch": {
        "tags": ["ActionRequests"],
        "summary": "Update action request status by actor (tenant-scoped)",
        "description": "Update succeeds only when the row's actorId matches the path; otherwise 404.",
        "security": [{ "n8nApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/XTenantId" },
          { "$ref": "#/components/parameters/ActorIdPath" },
          { "$ref": "#/components/parameters/ActionIdPath" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PatchActionStatusRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PatchActionStatusResponse" }
              }
            }
          },
